{"parentUuid":"5267f020-e50a-4cfc-85e1-20a366f336e1","isSidechain":true,"userType":"external","cwd":"/Users/so/MyWorkSpace/personal/care-inomi","sessionId":"6220edb9-5784-40a0-8127-bb33a23a843a","version":"2.1.19","gitBranch":"develop","agentId":"a86defc","slug":"synchronous-sleeping-plum","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VcTp52siAr5FMiFgtwvCRC","type":"tool_result","content":"     1→---\n     2→import ServiceLayout from \"../../layouts/ServiceLayout.astro\";\n     3→import Container from \"../../components/ui/Container.astro\";\n     4→import CTASection from \"../../components/sections/CTASection.astro\";\n     5→import FadeInSection from \"../../components/ui/FadeInSection\";\n     6→import CountUp from \"../../components/ui/CountUp\";\n     7→import { GraduationCap, Users, Clock, Target, Star, Building } from \"lucide-react\";\n     8→---\n     9→\n    10→<ServiceLayout\n    11→  title=\"研修・講演 | 合同会社あいのみ\"\n    12→  description=\"介護離職防止セミナーや管理職向け研修を企業に提供。仕事と介護の両立支援に関する知識と実践的なスキルを身につけていただきます。\"\n    13→  heroTitle=\"研修・講演\"\n    14→  heroSubtitle=\"介護離職防止に向けた企業研修・セミナーを提供。従業員の意識向上と組織づくりをサポートします。\"\n    15→>\n    16→  {/* Programs Section */}\n    17→  <section class=\"py-16 md:py-20\">\n    18→    <Container>\n    19→      <FadeInSection client:idle>\n    20→        <h2 class=\"text-2xl md:text-3xl font-bold text-neutral-900 mb-12 text-center\">\n    21→          研修プログラム\n    22→        </h2>\n    23→      </FadeInSection>\n    24→\n    25→      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\n    26→        {[\n    27→          {\n    28→            icon: \"building\",\n    29→            title: \"介護離職防止セミナー\",\n    30→            target: \"全従業員向け\",\n    31→            duration: \"60〜90分\",\n    32→            description: \"介護と仕事の両立に関する基礎知識と、利用できる制度・サービスについて解説します。\",\n    33→            topics: [\"介護保険制度の基礎\", \"両立支援制度の活用法\", \"相談窓口の紹介\"],\n    34→          },\n    35→          {\n    36→            icon: \"users\",\n    37→            title: \"管理職向け研修\",\n    38→            target: \"管理職・人事担当者向け\",\n    39→            duration: \"120分\",\n    40→            description: \"部下の介護状況を把握し、適切なサポートを行うためのマネジメントスキルを習得します。\",\n    41→            topics: [\"部下との面談スキル\", \"業務調整の方法\", \"ハラスメント防止\"],\n    42→          },\n    43→          {\n    44→            icon: \"graduation\",\n    45→            title: \"一般従業員向け研修\",\n    46→            target: \"一般従業員向け\",\n    47→            duration: \"90分\",\n    48→            description: \"介護に直面した時の心構えと、周囲への相談・協力の求め方を学びます。\",\n    49→            topics: [\"介護の心構え\", \"チームでの支え合い\", \"セルフケアの重要性\"],\n    50→          },\n    51→        ].map((program, index) => (\n    52→          <FadeInSection client:idle delay={index * 0.1}>\n    53→            <div class=\"bg-white rounded-2xl p-6 shadow-sm border border-neutral-100 h-full flex flex-col\">\n    54→              <div class=\"flex items-center gap-3 mb-4\">\n    55→                <div class=\"w-12 h-12 rounded-xl bg-sakura-50 flex items-center justify-center\">\n    56→                  {program.icon === \"building\" && <Building className=\"w-6 h-6 text-sakura-600\" />}\n    57→                  {program.icon === \"users\" && <Users className=\"w-6 h-6 text-sakura-600\" />}\n    58→                  {program.icon === \"graduation\" && <GraduationCap className=\"w-6 h-6 text-sakura-600\" />}\n    59→                </div>\n    60→                <div>\n    61→                  <h3 class=\"text-lg font-bold text-neutral-900\">{program.title}</h3>\n    62→                </div>\n    63→              </div>\n    64→\n    65→              <div class=\"flex gap-4 mb-4 text-sm\">\n    66→                <div class=\"flex items-center gap-1 text-neutral-600\">\n    67→                  <Target className=\"w-4 h-4\" />\n    68→                  <span>{program.target}</span>\n    69→                </div>\n    70→                <div class=\"flex items-center gap-1 text-neutral-600\">\n    71→                  <Clock className=\"w-4 h-4\" />\n    72→                  <span>{program.duration}</span>\n    73→                </div>\n    74→              </div>\n    75→\n    76→              <p class=\"text-neutral-600 text-sm mb-4 flex-1\">\n    77→                {program.description}\n    78→              </p>\n    79→\n    80→              <div class=\"pt-4 border-t border-neutral-100\">\n    81→                <p class=\"text-xs text-neutral-500 mb-2\">主なトピック</p>\n    82→                <ul class=\"space-y-1\">\n    83→                  {program.topics.map((topic) => (\n    84→                    <li class=\"flex items-center gap-2 text-sm text-neutral-700\">\n    85→                      <span class=\"w-1.5 h-1.5 rounded-full bg-sakura-400\"></span>\n    86→                      {topic}\n    87→                    </li>\n    88→                  ))}\n    89→                </ul>\n    90→              </div>\n    91→            </div>\n    92→          </FadeInSection>\n    93→        ))}\n    94→      </div>\n    95→    </Container>\n    96→  </section>\n    97→\n    98→  {/* Results Section */}\n    99→  <section class=\"py-16 md:py-20 bg-neutral-50\">\n   100→    <Container>\n   101→      <FadeInSection client:idle>\n   102→        <h2 class=\"text-2xl md:text-3xl font-bold text-neutral-900 mb-12 text-center\">\n   103→          研修実績\n   104→        </h2>\n   105→      </FadeInSection>\n   106→\n   107→      <div class=\"grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto\">\n   108→        {[\n   109→          { number: 50, suffix: \"社+\", label: \"導入企業数\" },\n   110→          { number: 5000, suffix: \"名+\", label: \"受講者数\" },\n   111→          { number: 95, suffix: \"%\", label: \"満足度\" },\n   112→          { number: 4.8, suffix: \"\", label: \"評価（5段階）\" },\n   113→        ].map((stat, index) => (\n   114→          <FadeInSection client:idle delay={index * 0.1}>\n   115→            <div class=\"bg-white rounded-2xl p-6 text-center shadow-sm border border-neutral-100\">\n   116→              <div class=\"text-3xl md:text-4xl font-bold text-sakura-600 mb-1\">\n   117→                <CountUp client:idle end={stat.number} suffix={stat.suffix} />\n   118→              </div>\n   119→              <p class=\"text-neutral-600 text-sm\">{stat.label}</p>\n   120→            </div>\n   121→          </FadeInSection>\n   122→        ))}\n   123→      </div>\n   124→    </Container>\n   125→  </section>\n   126→\n   127→  {/* Testimonials Section */}\n   128→  <section class=\"py-16 md:py-20\">\n   129→    <Container>\n   130→      <FadeInSection client:idle>\n   131→        <h2 class=\"text-2xl md:text-3xl font-bold text-neutral-900 mb-12 text-center\">\n   132→          受講者の声\n   133→        </h2>\n   134→      </FadeInSection>\n   135→\n   136→      <div class=\"grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto\">\n   137→        {[\n   138→          {\n   139→            quote: \"具体的な事例が多く、自分事として考えることができました。部下への接し方も変わりました。\",\n   140→            author: \"製造業 管理職\",\n   141→          },\n   142→          {\n   143→            quote: \"介護は他人事だと思っていましたが、いつ自分にも起こるかわからないと気づきました。\",\n   144→            author: \"IT企業 一般社員\",\n   145→          },\n   146→        ].map((testimonial, index) => (\n   147→          <FadeInSection client:idle delay={index * 0.1}>\n   148→            <div class=\"bg-white rounded-2xl p-6 shadow-sm border border-neutral-100\">\n   149→              <div class=\"flex gap-1 mb-4\">\n   150→                {[...Array(5)].map((_, i) => (\n   151→                  <Star className=\"w-5 h-5 fill-yellow-400 text-yellow-400\" />\n   152→                ))}\n   153→              </div>\n   154→              <p class=\"text-neutral-700 mb-4 italic\">\"{testimonial.quote}\"</p>\n   155→              <p class=\"text-sm text-neutral-500\">{testimonial.author}</p>\n   156→            </div>\n   157→          </FadeInSection>\n   158→        ))}\n   159→      </div>\n   160→    </Container>\n   161→  </section>\n   162→\n   163→  <CTASection\n   164→    heading=\"研修のお問い合わせ\"\n   165→    description=\"研修内容のカスタマイズや、オンライン開催のご相談も承ります。まずはお気軽にお問い合わせください。\"\n   166→  />\n   167→</ServiceLayout>\n   168→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"uuid":"7fd560d1-dd42-423c-b170-6d4c1a054df6","timestamp":"2026-01-26T14:01:20.514Z","sourceToolAssistantUUID":"5267f020-e50a-4cfc-85e1-20a366f336e1"}
