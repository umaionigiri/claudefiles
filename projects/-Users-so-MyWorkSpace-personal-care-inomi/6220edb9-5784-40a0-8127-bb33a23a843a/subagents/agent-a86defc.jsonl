{"parentUuid":"04fcf7ec-42dc-486f-a8ab-4040834d53cb","isSidechain":true,"userType":"external","cwd":"/Users/so/MyWorkSpace/personal/care-inomi","sessionId":"6220edb9-5784-40a0-8127-bb33a23a843a","version":"2.1.19","gitBranch":"develop","agentId":"a86defc","slug":"synchronous-sleeping-plum","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VG5nbtxi3VwbX7QwcnRbMR","type":"tool_result","content":"     1→---\n     2→import ServiceLayout from \"../../layouts/ServiceLayout.astro\";\n     3→import Container from \"../../components/ui/Container.astro\";\n     4→import CTASection from \"../../components/sections/CTASection.astro\";\n     5→import FadeInSection from \"../../components/ui/FadeInSection\";\n     6→import { GraduationCap, Users, Clock, Target, Building } from \"lucide-react\";\n     7→---\n     8→\n     9→<ServiceLayout\n    10→  title=\"研修・講演 | SHIRO CARE合同会社\"\n    11→  description=\"介護離職防止セミナーや管理職向け研修を企業に提供。仕事と介護の両立支援に関する知識と実践的なスキルを身につけていただきます。\"\n    12→  heroTitle=\"研修・講演\"\n    13→  heroSubtitle=\"介護離職防止に向けた企業研修・セミナーを提供。従業員の意識向上と組織づくりをサポートします。\"\n    14→>\n    15→  {/* Programs Section */}\n    16→  <section class=\"py-16 md:py-20\">\n    17→    <Container>\n    18→      <FadeInSection client:idle>\n    19→        <h2 class=\"text-2xl md:text-3xl font-bold text-neutral-900 mb-12 text-center\">\n    20→          研修プログラム\n    21→        </h2>\n    22→      </FadeInSection>\n    23→\n    24→      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\n    25→        {[\n    26→          {\n    27→            icon: \"building\",\n    28→            title: \"介護離職防止セミナー\",\n    29→            target: \"全従業員向け\",\n    30→            duration: \"60〜90分\",\n    31→            description: \"介護と仕事の両立に関する基礎知識と、利用できる制度・サービスについて解説します。\",\n    32→            topics: [\"介護保険制度の基礎\", \"両立支援制度の活用法\", \"相談窓口の紹介\"],\n    33→          },\n    34→          {\n    35→            icon: \"users\",\n    36→            title: \"管理職向け研修\",\n    37→            target: \"管理職・人事担当者向け\",\n    38→            duration: \"60分\",\n    39→            description: \"部下の介護状況を把握し、適切なサポートを行うためのマネジメントスキルを習得します。\",\n    40→            topics: [\"部下との面談スキル\", \"業務調整の方法\", \"ハラスメント防止\"],\n    41→          },\n    42→          {\n    43→            icon: \"graduation\",\n    44→            title: \"一般従業員向け研修\",\n    45→            target: \"一般従業員向け\",\n    46→            duration: \"60〜90分\",\n    47→            description: \"介護に直面した時の心構えと、周囲への相談・協力の求め方を学びます。茶話会を実施します。\",\n    48→            topics: [\"介護の心構え\", \"チームでの支え合い\", \"セルフケアの重要性\"],\n    49→          },\n    50→        ].map((program, index) => (\n    51→          <FadeInSection client:idle delay={index * 0.1}>\n    52→            <div class=\"bg-white rounded-2xl p-6 shadow-sm border border-neutral-100 h-full flex flex-col\">\n    53→              <div class=\"flex items-center gap-3 mb-4\">\n    54→                <div class=\"w-12 h-12 rounded-xl bg-sakura-50 flex items-center justify-center\">\n    55→                  {program.icon === \"building\" && <Building className=\"w-6 h-6 text-sakura-600\" />}\n    56→                  {program.icon === \"users\" && <Users className=\"w-6 h-6 text-sakura-600\" />}\n    57→                  {program.icon === \"graduation\" && <GraduationCap className=\"w-6 h-6 text-sakura-600\" />}\n    58→                </div>\n    59→                <div>\n    60→                  <h3 class=\"text-lg font-bold text-neutral-900\">{program.title}</h3>\n    61→                </div>\n    62→              </div>\n    63→\n    64→              <div class=\"flex gap-4 mb-4 text-sm\">\n    65→                <div class=\"flex items-center gap-1 text-neutral-600\">\n    66→                  <Target className=\"w-4 h-4\" />\n    67→                  <span>{program.target}</span>\n    68→                </div>\n    69→                <div class=\"flex items-center gap-1 text-neutral-600\">\n    70→                  <Clock className=\"w-4 h-4\" />\n    71→                  <span>{program.duration}</span>\n    72→                </div>\n    73→              </div>\n    74→\n    75→              <p class=\"text-neutral-600 text-sm mb-4 flex-1\">\n    76→                {program.description}\n    77→              </p>\n    78→\n    79→              <div class=\"pt-4 border-t border-neutral-100\">\n    80→                <p class=\"text-xs text-neutral-500 mb-2\">主なトピック</p>\n    81→                <ul class=\"space-y-1\">\n    82→                  {program.topics.map((topic) => (\n    83→                    <li class=\"flex items-center gap-2 text-sm text-neutral-700\">\n    84→                      <span class=\"w-1.5 h-1.5 rounded-full bg-sakura-400\"></span>\n    85→                      {topic}\n    86→                    </li>\n    87→                  ))}\n    88→                </ul>\n    89→              </div>\n    90→            </div>\n    91→          </FadeInSection>\n    92→        ))}\n    93→      </div>\n    94→    </Container>\n    95→  </section>\n    96→\n    97→  <CTASection\n    98→    heading=\"研修のお問い合わせ\"\n    99→    description=\"研修内容のカスタマイズや、オンライン開催のご相談も承ります。まずはお気軽にお問い合わせください。\"\n   100→  />\n   101→</ServiceLayout>\n   102→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"uuid":"00df48c7-6954-429c-8985-8e678a21e142","timestamp":"2026-01-26T14:01:48.193Z","sourceToolAssistantUUID":"04fcf7ec-42dc-486f-a8ab-4040834d53cb"}
