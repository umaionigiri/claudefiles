 37→            title: \"従業員向け相談窓口\",\n    38→            description: \"介護に関する不安や悩みを気軽に相談できる窓口を設置。専門家が親身に対応します。\",\n    39→          },\n    40→          {\n    41→            icon: \"briefcase\",\n    42→            title: \"介護離職防止コンサルティング\",\n    43→            description: \"企業の人事制度や働き方改革を支援。介護と仕事を両立できる環境づくりをサポート。\",\n    44→          },\n    45→          {\n    46→            icon: \"trending-up\",\n    47→            title: \"介護休業取得支援\",\n    48→            description: \"介護休業制度の活用方法をアドバイス。スムーズな休業取得と復帰をサポートします。\",\n    49→          },\n    50→        ].map((item, index) => (\n    51→          <FadeInSection client:idle delay={index * 0.1}>\n    52→            <div class=\"bg-white rounded-2xl p-6 shadow-sm border border-neutral-100 h-full\">\n    53→              <div class=\"w-12 h-12 rounded-xl bg-sakura-50 flex items-center justify-center mb-4\">\n    54→                {item.icon === \"users\" && <Users className=\"w-6 h-6 text-sakura-600\" />}\n    55→                {item.icon === \"briefcase\" && <Briefcase className=\"w-6 h-6 text-sakura-600\" />}\n    56→                {item.icon === \"trending-up\" && <TrendingUp className=\"w-6 h-6 text-sakura-600\" />}\n    57→              </div>\n    58→              <h3 class=\"text-lg font-bold text-neutral-900 mb-2\">{item.title}</h3>\n    59→              <p class=\"text-neutral-600 text-sm leading-relaxed\">{item.description}</p>\n    60→            </div>\n    61→          </FadeInSection>\n    62→        ))}\n    63→      </div>\n    64→    </Container>\n    65→  </section>\n    66→\n    67→  {/* Benefits Section */}\n    68→  <section class=\"py-16 md:py-20 bg-neutral-50\">\n    69→    <Container>\n    70→      <FadeInSection client:idle>\n    71→        <h2 class=\"text-2xl md:text-3xl font-bold text-neutral-900 mb-12 text-center\">\n    72→          導入効果\n    73→        </h2>\n    74→      </FadeInSection>\n    75→\n    76→      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\n    77→        {[\n