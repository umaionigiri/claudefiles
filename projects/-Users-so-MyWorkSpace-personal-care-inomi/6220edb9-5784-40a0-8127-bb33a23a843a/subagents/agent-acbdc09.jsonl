{"parentUuid":"51fbc0f2-d81d-43c2-9fef-4b80450ab858","isSidechain":true,"userType":"external","cwd":"/Users/so/MyWorkSpace/personal/care-inomi","sessionId":"6220edb9-5784-40a0-8127-bb33a23a843a","version":"2.1.19","gitBranch":"develop","agentId":"acbdc09","slug":"synchronous-sleeping-plum","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011C9RpCHkE96CBR24ATqFVf","type":"tool_result","content":"     1→---\n     2→import BaseLayout from \"../layouts/BaseLayout.astro\";\n     3→import Header from \"../components/common/Header.astro\";\n     4→import Footer from \"../components/common/Footer.astro\";\n     5→import Container from \"../components/ui/Container.astro\";\n     6→import CTASection from \"../components/sections/CTASection.astro\";\n     7→import Timeline from \"../components/sections/Timeline.astro\";\n     8→import FadeInSection from \"../components/ui/FadeInSection\";\n     9→import { COMPANY_INFO, SITE_CONFIG } from \"../lib/constants\";\n    10→import { Building, MapPin, Calendar, User, Briefcase } from \"lucide-react\";\n    11→---\n    12→\n    13→<BaseLayout\n    14→  title=\"会社概要 | 合同会社あいのみ\"\n    15→  description=\"合同会社あいのみの企業情報。仕事と介護の両立支援を通じて、誰もが安心して働き続けられる社会の実現を目指しています。\"\n    16→>\n    17→  <Header />\n    18→\n    19→  {/* Hero Section */}\n    20→  <section class=\"py-16 md:py-24 bg-gradient-to-br from-sakura-50 to-white\">\n    21→    <Container>\n    22→      <FadeInSection client:visible>\n    23→        <h1 class=\"text-3xl md:text-4xl lg:text-5xl font-bold text-neutral-900 mb-4 text-center\">\n    24→          会社概要\n    25→        </h1>\n    26→        <p class=\"text-lg text-neutral-600 max-w-2xl mx-auto text-center\">\n    27→          仕事と介護の両立支援を通じて、誰もが安心して働き続けられる社会を目指します\n    28→        </p>\n    29→      </FadeInSection>\n    30→    </Container>\n    31→  </section>\n    32→\n    33→  {/* Mission & Vision Section */}\n    34→  <section class=\"py-16 md:py-20\">\n    35→    <Container>\n    36→      <div class=\"max-w-4xl mx-auto\">\n    37→        <FadeInSection client:idle>\n    38→          <div class=\"text-center mb-16\">\n    39→            <h2 class=\"text-sm font-semibold uppercase tracking-wider text-sakura-600 mb-4\">\n    40→              Mission\n    41→            </h2>\n    42→            <p class=\"text-2xl md:text-3xl lg:text-4xl font-bold text-neutral-900 leading-relaxed\">\n    43→              仕事と介護の両立を、<br class=\"hidden md:block\" />\n    44→              あなたのそばで支えます\n    45→            </p>\n    46→          </div>\n    47→        </FadeInSection>\n    48→\n    49→        <FadeInSection client:idle delay={0.2}>\n    50→          <div class=\"bg-sakura-50 rounded-2xl p-8 md:p-12\">\n    51→            <h2 class=\"text-sm font-semibold uppercase tracking-wider text-sakura-600 mb-6\">\n    52→              Vision\n    53→            </h2>\n    54→            <p class=\"text-lg text-neutral-700 mb-8\">\n    55→              私たちが目指す社会\n    56→            </p>\n    57→            <ul class=\"space-y-4\">\n    58→              {[\n    59→                \"介護を理由に仕事を諦める人がいない社会\",\n    60→                \"企業と従業員が互いに支え合える職場環境\",\n    61→                \"介護と仕事の両立が当たり前になる社会\",\n    62→                \"誰もが安心して働き続けられる未来\",\n    63→              ].map((vision, index) => (\n    64→                <li class=\"flex items-start gap-3\">\n    65→                  <span class=\"flex-shrink-0 w-6 h-6 rounded-full bg-sakura-500 text-white flex items-center justify-center text-sm font-medium\">\n    66→                    {index + 1}\n    67→                  </span>\n    68→                  <span class=\"text-neutral-700\">{vision}</span>\n    69→                </li>\n    70→              ))}\n    71→            </ul>\n    72→          </div>\n    73→        </FadeInSection>\n    74→      </div>\n    75→    </Container>\n    76→  </section>\n    77→\n    78→  {/* Representative Section */}\n    79→  <section class=\"py-16 md:py-20 bg-neutral-50\">\n    80→    <Container>\n    81→      <FadeInSection client:idle>\n    82→        <h2 class=\"text-2xl md:text-3xl font-bold text-neutral-900 mb-12 text-center\">\n    83→          代表挨拶\n    84→        </h2>\n    85→      </FadeInSection>\n    86→\n    87→      <div class=\"max-w-4xl mx-auto\">\n    88→        <FadeInSection client:idle direction=\"left\">\n    89→          <div class=\"flex flex-col md:flex-row gap-8 items-center\">\n    90→            {/* Photo placeholder */}\n    91→            <div class=\"flex-shrink-0\">\n    92→              <div class=\"w-48 h-48 md:w-56 md:h-56 rounded-2xl bg-gradient-to-br from-sakura-200 to-sakura-100 flex items-center justify-center\">\n    93→                <User className=\"w-24 h-24 text-sakura-400\" />\n    94→              </div>\n    95→            </div>\n    96→\n    97→            {/* Message */}\n    98→            <div class=\"flex-1\">\n    99→              <p class=\"text-neutral-700 leading-relaxed mb-6\">\n   100→                高齢化が進む日本において、仕事と介護の両立は多くの方が直面する課題となっています。\n   101→                私たちは、介護に直面した方々が安心して働き続けられるよう、\n   102→                企業と従業員の両方をサポートする事業を展開しています。\n   103→              </p>\n   104→              <p class=\"text-neutral-700 leading-relaxed mb-6\">\n   105→                産業ケアマネージャーとして培った経験を活かし、\n   106→                一人ひとりに寄り添ったサポートを提供してまいります。\n   107→              </p>\n   108→              <div class=\"text-right\">\n   109→                <p class=\"text-sakura-600 font-bold\">合同会社あいのみ 代表</p>\n   110→              </div>\n   111→            </div>\n   112→          </div>\n   113→        </FadeInSection>\n   114→      </div>\n   115→    </Container>\n   116→  </section>\n   117→\n   118→  {/* Company Info Section */}\n   119→  <section class=\"py-16 md:py-20\">\n   120→    <Container>\n   121→      <FadeInSection client:idle>\n   122→        <h2 class=\"text-2xl md:text-3xl font-bold text-neutral-900 mb-12 text-center\">\n   123→          会社情報\n   124→        </h2>\n   125→      </FadeInSection>\n   126→\n   127→      <div class=\"max-w-3xl mx-auto\">\n   128→        <FadeInSection client:idle>\n   129→          <div class=\"bg-white rounded-2xl shadow-sm border border-neutral-100 overflow-hidden\">\n   130→            <table class=\"w-full\">\n   131→              <tbody class=\"divide-y divide-neutral-100\">\n   132→                {[\n   133→                  { icon: Building, label: \"会社名\", value: COMPANY_INFO.name },\n   134→                  { icon: MapPin, label: \"所在地\", value: COMPANY_INFO.address },\n   135→                  { icon: Calendar, label: \"設立\", value: COMPANY_INFO.founded },\n   136→                  { icon: User, label: \"代表者\", value: COMPANY_INFO.representative || \"（準備中）\" },\n   137→                  { icon: Briefcase, label: \"事業内容\", value: COMPANY_INFO.business.join(\"、\") },\n   138→                ].map((row) => (\n   139→                  <tr>\n   140→                    <th class=\"px-6 py-4 bg-neutral-50 text-left font-medium text-neutral-700 w-1/3\">\n   141→                      <div class=\"flex items-center gap-2\">\n   142→                        <row.icon className=\"w-4 h-4 text-sakura-500\" />\n   143→                        {row.label}\n   144→                      </div>\n   145→                    </th>\n   146→                    <td class=\"px-6 py-4 text-neutral-600\">\n   147→                      {row.value}\n   148→                    </td>\n   149→                  </tr>\n   150→                ))}\n   151→              </tbody>\n   152→            </table>\n   153→          </div>\n   154→        </FadeInSection>\n   155→      </div>\n   156→    </Container>\n   157→  </section>\n   158→\n   159→  {/* History Section */}\n   160→  <section class=\"py-16 md:py-20 bg-neutral-50\">\n   161→    <Container>\n   162→      <FadeInSection client:idle>\n   163→        <h2 class=\"text-2xl md:text-3xl font-bold text-neutral-900 mb-12 text-center\">\n   164→          沿革\n   165→        </h2>\n   166→      </FadeInSection>\n   167→\n   168→      <div class=\"max-w-3xl mx-auto\">\n   169→        <Timeline\n   170→          events={[\n   171→            { year: \"2024年\", title: \"会社設立\", description: \"合同会社あいのみを設立。産業ケアマネ事業を開始。\" },\n   172→            { year: \"2024年\", title: \"サービス開始\", description: \"企業向け介護離職防止支援サービスの提供を開始。\" },\n   173→            { year: \"2025年\", title: \"研修事業開始\", description: \"企業向け研修・講演サービスを本格展開。\" },\n   174→          ]}\n   175→        />\n   176→      </div>\n   177→    </Container>\n   178→  </section>\n   179→\n   180→  <CTASection />\n   181→\n   182→  <Footer />\n   183→</BaseLayout>\n   184→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"uuid":"741da3fd-f9df-4458-ac54-3a7b6c7ad39a","timestamp":"2026-01-26T14:01:21.249Z","sourceToolAssistantUUID":"51fbc0f2-d81d-43c2-9fef-4b80450ab858"}
