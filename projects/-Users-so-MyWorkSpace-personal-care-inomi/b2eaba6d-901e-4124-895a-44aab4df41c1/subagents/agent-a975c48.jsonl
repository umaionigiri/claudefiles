{"parentUuid":null,"isSidechain":true,"userType":"external","cwd":"/Users/so/MyWorkSpace/personal/care-inomi/.worktrees/feature/initial-setup","sessionId":"b2eaba6d-901e-4124-895a-44aab4df41c1","version":"2.1.19","gitBranch":"develop","agentId":"a975c48","slug":"giggly-watching-meteor","type":"user","message":{"role":"user","content":"Implement the training service page.\n\nWorking directory: /Users/so/MyWorkSpace/personal/care-inomi/.worktrees/feature/initial-setup\n\nCreate src/pages/services/training.astro:\n\n```astro\n---\nimport ServiceLayout from \"../../layouts/ServiceLayout.astro\";\nimport Container from \"../../components/ui/Container.astro\";\nimport CTASection from \"../../components/sections/CTASection.astro\";\nimport FadeInSection from \"../../components/ui/FadeInSection\";\nimport CountUp from \"../../components/ui/CountUp\";\nimport { GraduationCap, Users, Clock, Target, Star, Building } from \"lucide-react\";\n---\n\n<ServiceLayout\n  title=\"研修・講演 | 合同会社あいのみ\"\n  description=\"介護離職防止セミナーや管理職向け研修を企業に提供。仕事と介護の両立支援に関する知識と実践的なスキルを身につけていただきます。\"\n  heroTitle=\"研修・講演\"\n  heroSubtitle=\"介護離職防止に向けた企業研修・セミナーを提供。従業員の意識向上と組織づくりをサポートします。\"\n>\n  {/* Programs Section */}\n  <section class=\"py-16 md:py-20\">\n    <Container>\n      <FadeInSection client:idle>\n        <h2 class=\"text-2xl md:text-3xl font-bold text-neutral-900 mb-12 text-center\">\n          研修プログラム\n        </h2>\n      </FadeInSection>\n\n      <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\n        {[\n          {\n            icon: \"building\",\n            title: \"介護離職防止セミナー\",\n            target: \"全従業員向け\",\n            duration: \"60〜90分\",\n            description: \"介護と仕事の両立に関する基礎知識と、利用できる制度・サービスについて解説します。\",\n            topics: [\"介護保険制度の基礎\", \"両立支援制度の活用法\", \"相談窓口の紹介\"],\n          },\n          {\n            icon: \"users\",\n            title: \"管理職向け研修\",\n            target: \"管理職・人事担当者向け\",\n            duration: \"120分\",\n            description: \"部下の介護状況を把握し、適切なサポートを行うためのマネジメントスキルを習得します。\",\n            topics: [\"部下との面談スキル\", \"業務調整の方法\", \"ハラスメント防止\"],\n          },\n          {\n            icon: \"graduation\",\n            title: \"一般従業員向け研修\",\n            target: \"一般従業員向け\",\n            duration: \"90分\",\n            description: \"介護に直面した時の心構えと、周囲への相談・協力の求め方を学びます。\",\n            topics: [\"介護の心構え\", \"チームでの支え合い\", \"セルフケアの重要性\"],\n          },\n        ].map((program, index) => (\n          <FadeInSection client:idle delay={index * 0.1}>\n            <div class=\"bg-white rounded-2xl p-6 shadow-sm border border-neutral-100 h-full flex flex-col\">\n              <div class=\"flex items-center gap-3 mb-4\">\n                <div class=\"w-12 h-12 rounded-xl bg-sakura-50 flex items-center justify-center\">\n                  {program.icon === \"building\" && <Building className=\"w-6 h-6 text-sakura-600\" />}\n                  {program.icon === \"users\" && <Users className=\"w-6 h-6 text-sakura-600\" />}\n                  {program.icon === \"graduation\" && <GraduationCap className=\"w-6 h-6 text-sakura-600\" />}\n                </div>\n                <div>\n                  <h3 class=\"text-lg font-bold text-neutral-900\">{program.title}</h3>\n                </div>\n              </div>\n\n              <div class=\"flex gap-4 mb-4 text-sm\">\n                <div class=\"flex items-center gap-1 text-neutral-600\">\n                  <Target className=\"w-4 h-4\" />\n                  <span>{program.target}</span>\n                </div>\n                <div class=\"flex items-center gap-1 text-neutral-600\">\n                  <Clock className=\"w-4 h-4\" />\n                  <span>{program.duration}</span>\n                </div>\n              </div>\n\n              <p class=\"text-neutral-600 text-sm mb-4 flex-1\">\n                {program.description}\n              </p>\n\n              <div class=\"pt-4 border-t border-neutral-100\">\n                <p class=\"text-xs text-neutral-500 mb-2\">主なトピック</p>\n                <ul class=\"space-y-1\">\n                  {program.topics.map((topic) => (\n                    <li class=\"flex items-center gap-2 text-sm text-neutral-700\">\n                      <span class=\"w-1.5 h-1.5 rounded-full bg-sakura-400\"></span>\n                      {topic}\n                    </li>\n                  ))}\n                </ul>\n              </div>\n            </div>\n          </FadeInSection>\n        ))}\n      </div>\n    </Container>\n  </section>\n\n  {/* Results Section */}\n  <section class=\"py-16 md:py-20 bg-neutral-50\">\n    <Container>\n      <FadeInSection client:idle>\n        <h2 class=\"text-2xl md:text-3xl font-bold text-neutral-900 mb-12 text-center\">\n          研修実績\n        </h2>\n      </FadeInSection>\n\n      <div class=\"grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto\">\n        {[\n          { number: 50, suffix: \"社+\", label: \"導入企業数\" },\n          { number: 5000, suffix: \"名+\", label: \"受講者数\" },\n          { number: 95, suffix: \"%\", label: \"満足度\" },\n          { number: 4.8, suffix: \"\", label: \"評価（5段階）\" },\n        ].map((stat, index) => (\n          <FadeInSection client:idle delay={index * 0.1}>\n            <div class=\"bg-white rounded-2xl p-6 text-center shadow-sm border border-neutral-100\">\n              <div class=\"text-3xl md:text-4xl font-bold text-sakura-600 mb-1\">\n                <CountUp client:idle end={stat.number} suffix={stat.suffix} />\n              </div>\n              <p class=\"text-neutral-600 text-sm\">{stat.label}</p>\n            </div>\n          </FadeInSection>\n        ))}\n      </div>\n    </Container>\n  </section>\n\n  {/* Testimonials Section */}\n  <section class=\"py-16 md:py-20\">\n    <Container>\n      <FadeInSection client:idle>\n        <h2 class=\"text-2xl md:text-3xl font-bold text-neutral-900 mb-12 text-center\">\n          受講者の声\n        </h2>\n      </FadeInSection>\n\n      <div class=\"grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto\">\n        {[\n          {\n            quote: \"具体的な事例が多く、自分事として考えることができました。部下への接し方も変わりました。\",\n            author: \"製造業 管理職\",\n          },\n          {\n            quote: \"介護は他人事だと思っていましたが、いつ自分にも起こるかわからないと気づきました。\",\n            author: \"IT企業 一般社員\",\n          },\n        ].map((testimonial, index) => (\n          <FadeInSection client:idle delay={index * 0.1}>\n            <div class=\"bg-white rounded-2xl p-6 shadow-sm border border-neutral-100\">\n              <div class=\"flex gap-1 mb-4\">\n                {[...Array(5)].map((_, i) => (\n                  <Star className=\"w-5 h-5 fill-yellow-400 text-yellow-400\" />\n                ))}\n              </div>\n              <p class=\"text-neutral-700 mb-4 italic\">\"{testimonial.quote}\"</p>\n              <p class=\"text-sm text-neutral-500\">{testimonial.author}</p>\n            </div>\n          </FadeInSection>\n        ))}\n      </div>\n    </Container>\n  </section>\n\n  <CTASection\n    heading=\"研修のお問い合わせ\"\n    description=\"研修内容のカスタマイズや、オンライン開催のご相談も承ります。まずはお気軽にお問い合わせください。\"\n  />\n</ServiceLayout>\n```\n\nUse Write tool to create the file."},"uuid":"5786e822-1bed-4818-b348-f122e34ab845","timestamp":"2026-01-25T15:36:52.004Z"}
