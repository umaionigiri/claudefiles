i>\n          <li class=\"text-neutral-800 font-medium\" aria-current=\"page\">\n            {heroTitle}\n          </li>\n        </ol>\n      </nav>\n      \n      <h1 class=\"text-3xl md:text-4xl lg:text-5xl font-bold text-neutral-900 mb-4\">\n        {heroTitle}\n      </h1>\n      {heroSubtitle && (\n        <p class=\"text-lg md:text-xl text-neutral-600 max-w-2xl\">\n          {heroSubtitle}\n        </p>\n      )}\n    </Container>\n  </section>\n  \n  {/* Main Content */}\n  <main>\n    <slot />\n  </main>\n  \n  <Footer />\n</BaseLayout>\n```\n\n2. Create src/components/common/Footer.astro:\n\n```astro\n---\nimport Container from \"../ui/Container.astro\";\nimport { SITE_CONFIG, LINE_CONFIG, NAV_ITEMS } from \"../../lib/constants\";\n\nconst currentYear = new Date().getFullYear();\n\nconst footerLinks = [\n  { label: \"プライバシーポリシー\", href: \"/privacy\" },\n  { label: \"サイトマップ\", href: \"/sitemap\" },\n];\n---\n\n<footer class=\"bg-neutral-900 text-white py-12 md:py-16\">\n  <Container>\n    <div class=\"grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12\">\n      {/* Company Info */}\n      <div>\n        <a href=\"/\" class=\"text-xl font-bold text-sakura-400 hover:text-sakura-300 transition-colors\">\n          あいのみ\n        </a>\n        <p class=\"mt-4 text-neutral-400 text-sm leading-relaxed\">\n          {SITE_CONFIG.description}\n        </p>\n      </div>\n\n      {/* Navigation */}\n      <div>\n        <h2 class=\"text-sm font-semibold uppercase tracking-wider text-neutral-300 mb-4\">\n          ナビゲーション\n        </h2>\n        <ul class=\"space-y-2\">\n          {NAV_ITEMS.map((item) => (\n            <li>\n              <a\n                href={item.href}\n                class=\"text-neutral-400 hover:text-sakura-400 transition-colors text-sm\"\n              >\n                {item.label}\n              </a>\n            </li>\n          ))}\n        </ul>\n      </div>\n\n      {/* Contact */}\n      <div>\n        <h2 class=\"text-sm font-semibold uppercase tracking-wider text-neutral-300 mb-4\">\n          お問い合わせ\n        </h2>\n        <p class=\"text-neutral-400 text-sm mb-4\">\n          LINEでお気軽にご相談ください\n        </p>\n        <a\n          href={LINE_CONFIG.url}\n          target=\"_blank\"\n          rel=\"noopener noreferrer\"\n          class=\"inline-flex items-center gap-2 bg-[#06C755] hover:bg-[#05b34d] text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors\"\n        >\n          <svg class=\"w-5 h-5\" viewBox=\"0 0 24 24\" fill=\"currentColor\">\n            <path d=\"M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314\"/>\n          </svg>\n          LINEで相談する\n        </a>\n      </div>\n    </div>\n\n    {/* Bottom Bar */}\n    <div class=\"mt-12 pt-8 border-t border-neutral-800\">\n      <div class=\"flex flex-col md:flex-row justify-between items-center gap-4\">\n        <p class=\"text-neutral-500 text-sm\">\n          © {currentYear} {SITE_CONFIG.name}. All rights reserved.\n