{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(pnpm *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git worktree*)",
      "Bash(ls:*)",
      "Bash(azd env get-values:*)",
      "Bash(az account show:*)",
      "Bash(az login:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "Read(//Users/so/.claude/**)",
      "mcp__azure__subscription_list",
      "mcp__azure__documentation",
      "mcp__o3__o3_chat",
      "Read(//Users/so/MyWorkSpace/scibit/**)",
      "WebFetch(domain:wmg2027.jp)",
      "mcp__azure__search",
      "mcp__azure__storage",
      "Bash(curl:*)",
      "Bash(az search service update:*)",
      "Bash(az rest:*)",
      "Bash(python3:*)",
      "Bash(az account list:*)",
      "Bash(az resource list:*)",
      "Bash(az group list:*)",
      "mcp__azure__role",
      "Bash(az role assignment list:*)",
      "Bash(node:*)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(npx tsc *)",
      "Bash(az storage account keys list:*)",
      "Bash(az storage account show:*)",
      "Bash(az storage account update:*)",
      "Bash(az storage blob list:*)",
      "Bash(git restore:*)",
      "mcp__filesystem__list_directory",
      "mcp__filesystem__directory_tree",
      "Bash(wc:*)"
    ],
    "defaultMode": "default",
    "additionalDirectories": [
      "/tmp"
    ]
  },
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "70"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r 'if .tool_input.command | test(\"rm -rf|dd if=|:(){ :|:& };:\") then {\"decision\": \"block\", \"reason\": \"危険なコマンドは実行できません。別の方法を検討してください。\"} else empty end'"
          },
          {
            "type": "command",
            "command": "jq -r 'if .tool_input.command | test(\"^git push.*(--force|-f)\") then {\"decision\": \"block\", \"reason\": \"force push は危険です。本当に必要な場合は手動で実行してください。\"} else empty end'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path | select(endswith(\".js\") or endswith(\".ts\") or endswith(\".jsx\") or endswith(\".tsx\"))' | xargs -r prettier --write"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '\"タスク完了: \" + .stop_hook_active'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo \"Claude Code: $(jq -r '.message')\" | terminal-notifier -title 'Claude Code'"
          }
        ]
      }
    ]
  },
  "skipDangerousModePermissionPrompt": true
}
