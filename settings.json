{
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "70",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(pnpm *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git worktree*)",
      "Bash(ls:*)",
      "Bash(azd env get-values:*)",
      "Bash(az account show:*)",
      "Bash(az login:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "Read(//Users/so/.claude/**)",
      "mcp__azure__subscription_list",
      "mcp__azure__documentation",
      "mcp__o3__o3_chat",
      "Read(//Users/so/MyWorkSpace/scibit/**)",
      "WebFetch(domain:wmg2027.jp)",
      "mcp__azure__search",
      "mcp__azure__storage",
      "Bash(curl:*)",
      "Bash(az search service update:*)",
      "Bash(az rest:*)",
      "Bash(python3:*)",
      "Bash(az account list:*)",
      "Bash(az resource list:*)",
      "Bash(az group list:*)",
      "mcp__azure__role",
      "Bash(az role assignment list:*)",
      "Bash(node:*)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(npx tsc *)",
      "Bash(az storage account keys list:*)",
      "Bash(az storage account show:*)",
      "Bash(az storage account update:*)",
      "Bash(az storage blob list:*)",
      "Bash(git restore:*)",
      "mcp__filesystem__list_directory",
      "mcp__filesystem__directory_tree",
      "Bash(wc:*)",
      "mcp__github__list_pull_requests",
      "mcp__github__create_pull_request",
      "Bash(git push:*)",
      "mcp__github__update_issue",
      "Bash(git fetch:*)",
      "Bash(git ls-tree:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git remote add:*)",
      "Bash(git clone:*)",
      "Bash(git pull:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(docker:*)",
      "Bash(kubectl:*)",
      "Bash(aws:*)",
      "Bash(az:*)",
      "Bash(gcloud:*)",
      "Bash(terraform apply:*)",
      "Bash(terraform destroy:*)",
      "Bash(npm publish:*)",
      "Bash(npm install:*)",
      "Bash(npm i:*)",
      "Bash(pip install:*)",
      "Bash(pip3 install:*)",
      "Bash(pipenv install:*)",
      "Bash(poetry add:*)",
      "Bash(go get:*)",
      "Bash(go install:*)",
      "Bash(yarn add:*)",
      "Bash(yarn install:*)",
      "Bash(bundle install:*)",
      "Bash(cargo install:*)",
      "Bash(cargo build:*)",
      "Bash(composer require:*)",
      "Bash(composer install:*)",
      "Bash(mvn install:*)",
      "Bash(gradle install:*)",
      "Bash(apt install:*)",
      "Bash(apt-get install:*)",
      "Bash(yum install:*)",
      "Bash(brew install:*)",
      "Bash(choco install:*)",
      "Bash(wget:*)",
      "Bash(make:*)",
      "Bash(cmake:*)",
      "Read(**/.env*)",
      "Read(**/secrets/**)",
      "Read(**/*secret*)",
      "Read(**/*password*)",
      "Read(**/*token*)",
      "Read(**/.git/config)",
      "Write(**/Dockerfile)",
      "Write(**/.github/workflows/*)",
      "Write(**/*.sh)",
      "Write(**/*.bash)",
      "Write(**/*.ps1)",
      "Edit(**/Dockerfile)",
      "Edit(**/.github/workflows/*)",
      "Edit(**/*.sh)",
      "Edit(**/*.bash)",
      "Edit(**/*.ps1)",
      "Edit(**/package-lock.json)",
      "Edit(**/yarn.lock)",
      "Edit(**/pnpm-lock.yaml)",
      "Edit(**/Gemfile.lock)",
      "Edit(**/poetry.lock)",
      "Edit(**/Pipfile.lock)",
      "Edit(**/composer.lock)",
      "Edit(**/Cargo.lock)",
      "Edit(**/go.sum)",
      "Edit(**/.git/**)"
    ],
    "defaultMode": "dontAsk",
    "additionalDirectories": [
      "/tmp"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const cmd=JSON.parse(d).tool_input.command||'';if(/rm -rf|dd if=|:\\(\\)\\{ :\\|:& \\};:/.test(cmd))console.log(JSON.stringify({decision:'block',reason:'Dangerous command blocked. Consider an alternative approach.'}))})\""
          },
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const cmd=JSON.parse(d).tool_input.command||'';if(/^git push.*(--force|-f)/.test(cmd))console.log(JSON.stringify({decision:'block',reason:'Force push blocked. Run manually if truly needed.'}))})\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const f=JSON.parse(d).tool_input.file_path||'';if(/\\.(js|ts|jsx|tsx)$/.test(f))console.log(f)})\" | xargs -r prettier --write"
          },
          {
            "type": "command",
            "command": "bash \"${USERPROFILE:-/Users/so}/.claude/scripts/auto-sync.sh\"",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"${USERPROFILE:-/Users/so}/.claude\" && git fetch origin 2>/dev/null && BEHIND=$(git rev-list HEAD..origin/main --count 2>/dev/null || echo 0) && echo \"[セッション開始] ブランチ: $(git rev-parse --abbrev-ref HEAD) / 最新コミット: $(git log --oneline -1) / リモート差分: ${BEHIND}件遅れ\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const j=JSON.parse(d);console.log('Task complete: '+j.stop_hook_active)})\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{const m=JSON.parse(d).message||'';console.log('Claude Code: '+m)})\""
          }
        ]
      }
    ]
  },
  "language": "japanese",
  "skipDangerousModePermissionPrompt": true
}
