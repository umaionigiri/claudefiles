---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/common/Header.astro";
import Footer from "../components/common/Footer.astro";
import Container from "../components/ui/Container.astro";
import CTASection from "../components/sections/CTASection.astro";
import Timeline from "../components/sections/Timeline.astro";
import FadeInSection from "../components/ui/FadeInSection";
import { COMPANY_INFO } from "../lib/constants";
import { Building, Home, MapPin, Calendar, User, Briefcase } from "lucide-react";
---

<BaseLayout
  title="会社概要 | SHIRO CARE合同会社"
  description="SHIRO CARE合同会社の企業情報。仕事と介護の両立支援を通じて、誰もが安心して働き続けられる社会の実現を目指しています。"
>
  <Header />

  {/* Hero Section */}
  <section class="py-16 md:py-24 bg-gradient-to-br from-sakura-50 to-white">
    <Container>
      <FadeInSection client:visible>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-neutral-900 mb-4 text-center">
          会社概要
        </h1>
        <p class="text-lg text-neutral-600 max-w-2xl mx-auto text-center">
          仕事と介護の両立支援を通じて、誰もが安心して働き続けられる社会を目指します
        </p>
      </FadeInSection>
    </Container>
  </section>

  {/* Mission & Vision Section */}
  <section class="py-16 md:py-20">
    <Container>
      <div class="max-w-4xl mx-auto">
        <FadeInSection client:idle>
          <div class="text-center mb-16">
            <h2 class="text-sm font-semibold uppercase tracking-wider text-sakura-600 mb-4">
              Mission
            </h2>
            <p class="text-2xl md:text-3xl lg:text-4xl font-bold text-neutral-900 leading-relaxed">
              仕事と介護の両立を、<br class="hidden md:block" />
              あなたのそばで支えます
            </p>
          </div>
        </FadeInSection>

        <FadeInSection client:idle delay={0.2}>
          <div class="bg-sakura-50 rounded-2xl p-8 md:p-12">
            <h2 class="text-sm font-semibold uppercase tracking-wider text-sakura-600 mb-6">
              Vision
            </h2>
            <p class="text-lg text-neutral-700 mb-8">
              私たちが目指す社会
            </p>
            <ul class="space-y-4">
              {[
                "介護を理由に仕事を諦める人がいない社会",
                "企業と従業員が互いに支え合える職場環境",
                "介護と仕事の両立が当たり前になる社会",
                "誰もが安心して働き続けられる未来",
              ].map((vision, index) => (
                <li class="flex items-start gap-3">
                  <span class="flex-shrink-0 w-6 h-6 rounded-full bg-sakura-500 text-white flex items-center justify-center text-sm font-medium">
                    {index + 1}
                  </span>
                  <span class="text-neutral-700">{vision}</span>
                </li>
              ))}
            </ul>
          </div>
        </FadeInSection>
      </div>
    </Container>
  </section>

  {/* Representative Section */}
  <section class="py-16 md:py-20 bg-neutral-50">
    <Container>
      <FadeInSection client:idle>
        <h2 class="text-2xl md:text-3xl font-bold text-neutral-900 mb-12 text-center">
          代表挨拶
        </h2>
      </FadeInSection>

      <div class="max-w-4xl mx-auto">
        <FadeInSection client:idle direction="left">
          <div class="flex flex-col md:flex-row gap-8 items-start">
            {/* Photo */}
            <div class="flex-shrink-0">
              <img
                src="/images/ceo.png"
                alt="代表 大城美佐子"
                class="w-48 h-48 md:w-56 md:h-56 rounded-2xl object-cover"
              />
            </div>

            {/* Message */}
            <div class="flex-1">
              <p class="text-neutral-700 leading-relaxed mb-6">
                高齢化が進む日本において、仕事と介護の両立は多くの方が直面する課題となっています。
                私たちは、介護に直面した方々が安心して働き続けられるよう、
                企業と従業員の両方をサポートする事業を展開しています。
              </p>
              <p class="text-neutral-700 leading-relaxed mb-6">
                ケアマネージャーとして培った経験を活かし、
                一人ひとりに寄り添ったサポートを提供してまいります。
              </p>
              <div class="text-right">
                <p class="text-sakura-600 font-bold">SHIRO CARE合同会社 代表</p>
                <p class="text-sm text-neutral-600 mt-1">大城美佐子</p>
              </div>

              {/* Qualifications */}
              <div class="mt-6 pt-6 border-t border-neutral-200">
                <p class="text-sm font-semibold text-neutral-700 mb-3">保有資格</p>
                <div class="flex flex-wrap gap-2">
                  {["主任介護支援専門員", "認知症ケア専門士", "介護福祉士", "福祉住環境コーディネーター"].map((cert) => (
                    <span class="px-3 py-1 bg-sakura-50 text-sakura-700 text-sm rounded-full">
                      {cert}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </FadeInSection>
      </div>
    </Container>
  </section>

  {/* Company Info Section */}
  <section class="py-16 md:py-20">
    <Container>
      <FadeInSection client:idle>
        <h2 class="text-2xl md:text-3xl font-bold text-neutral-900 mb-12 text-center">
          会社情報
        </h2>
      </FadeInSection>

      <div class="max-w-3xl mx-auto">
        <FadeInSection client:idle>
          <div class="bg-white rounded-2xl shadow-sm border border-neutral-100 overflow-hidden">
            <table class="w-full">
              <tbody class="divide-y divide-neutral-100">
                {[
                  { icon: Building, label: "会社名", value: COMPANY_INFO.name },
                  { icon: Home, label: "事業所名", value: "居宅介護支援事業所あいのみ" },
                  { icon: MapPin, label: "所在地", value: COMPANY_INFO.address },
                  { icon: Calendar, label: "設立", value: COMPANY_INFO.founded },
                  { icon: User, label: "代表者", value: COMPANY_INFO.representative || "（準備中）" },
                  { icon: Briefcase, label: "事業内容", value: COMPANY_INFO.business.join("、") },
                ].map((row) => (
                  <tr>
                    <th class="px-6 py-4 bg-neutral-50 text-left font-medium text-neutral-700 w-1/3">
                      <div class="flex items-center gap-2">
                        <row.icon className="w-4 h-4 text-sakura-500" />
                        {row.label}
                      </div>
                    </th>
                    <td class="px-6 py-4 text-neutral-600">
                      {row.value}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </FadeInSection>
      </div>
    </Container>
  </section>

  {/* History Section */}
  <section class="py-16 md:py-20 bg-neutral-50">
    <Container>
      <FadeInSection client:idle>
        <h2 class="text-2xl md:text-3xl font-bold text-neutral-900 mb-12 text-center">
          沿革
        </h2>
      </FadeInSection>

      <div class="max-w-3xl mx-auto">
        <Timeline
          events={[
            { year: "2023年11月", title: "会社設立", description: "SHIRO CARE合同会社を設立。" },
            { year: "2024年4月", title: "事業所開設", description: "居宅介護支援事業所あいのみを開設。ケアマネジメント事業を開始。" },
            { year: "2026年", title: "新規事業開始", description: "産業ケアマネ事業、研修・講演事業を開始。" },
          ]}
        />
      </div>
    </Container>
  </section>

  <CTASection />

  <Footer />
</BaseLayout>
