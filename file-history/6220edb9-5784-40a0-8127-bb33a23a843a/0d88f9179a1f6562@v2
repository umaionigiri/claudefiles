---
import Container from "../ui/Container.astro";
import { SITE_CONFIG, LINE_CONFIG, NAV_ITEMS } from "../../lib/constants";

const currentYear = new Date().getFullYear();

const footerLinks = [
  { label: "プライバシーポリシー", href: "/privacy" },
  { label: "サイトマップ", href: "/sitemap-index.xml" },
];
---

<footer class="bg-neutral-100 text-neutral-800 py-12 md:py-16">
  <Container>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      {/* Company Info */}
      <div>
        <a href="/" class="text-xl font-bold text-sakura-600 hover:text-sakura-500 transition-colors">
          あいのみ
        </a>
        <p class="mt-4 text-neutral-600 text-sm leading-relaxed">
          {SITE_CONFIG.description}
        </p>
      </div>

      {/* Navigation */}
      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-700 mb-4">
          ナビゲーション
        </h2>
        <ul class="space-y-2">
          {NAV_ITEMS.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-neutral-600 hover:text-sakura-600 transition-colors text-sm"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Contact */}
      <div>
        <h2 class="text-sm font-semibold uppercase tracking-wider text-neutral-700 mb-4">
          お問い合わせ
        </h2>
        <p class="text-neutral-600 text-sm mb-4">
          LINEでお気軽にご相談ください
        </p>
        <a
          href={LINE_CONFIG.url}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[#06C755] hover:bg-[#05b34d] text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
          </svg>
          LINEで相談する
        </a>
      </div>
    </div>

    {/* Bottom Bar */}
    <div class="mt-12 pt-8 border-t border-neutral-200">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-neutral-600 text-sm">
          © {currentYear} {SITE_CONFIG.name}. All rights reserved.
        </p>
        <ul class="flex items-center gap-6">
          {footerLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-neutral-600 hover:text-sakura-600 transition-colors text-sm"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </Container>
</footer>
