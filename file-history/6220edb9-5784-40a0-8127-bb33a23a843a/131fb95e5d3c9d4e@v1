---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/common/Header.astro";
import Footer from "../components/common/Footer.astro";
import Container from "../components/ui/Container.astro";
import Button from "../components/ui/Button.astro";
import QRCode from "../components/ui/QRCode.astro";
import FadeInSection from "../components/ui/FadeInSection";
import { LINE_CONFIG } from "../lib/constants";
import { MessageCircle, Clock, CheckCircle, ArrowRight } from "lucide-react";
---

<BaseLayout
  title="お問い合わせ | 合同会社あいのみ"
  description="合同会社あいのみへのお問い合わせはLINEからお気軽にどうぞ。平日9:00〜18:00、24時間以内にご返信いたします。"
>
  <Header />

  {/* Hero Section */}
  <section class="py-16 md:py-24 bg-gradient-to-br from-sakura-50 to-white">
    <Container>
      <FadeInSection client:visible>
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-neutral-900 mb-4 text-center">
          お問い合わせ
        </h1>
        <p class="text-lg text-neutral-600 max-w-2xl mx-auto text-center">
          サービスに関するご質問やご相談は、LINEからお気軽にお問い合わせください
        </p>
      </FadeInSection>
    </Container>
  </section>

  {/* LINE Contact Section */}
  <section class="py-16 md:py-20">
    <Container>
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          {/* QR Code Side */}
          <FadeInSection client:idle direction="left">
            <div class="text-center">
              <QRCode src={LINE_CONFIG.qrCodePath} size={220} />
              <p class="mt-4 text-neutral-600">
                スマートフォンでQRコードを読み取ってください
              </p>
            </div>
          </FadeInSection>

          {/* Info Side */}
          <FadeInSection client:idle direction="right">
            <div>
              <h2 class="text-2xl font-bold text-neutral-900 mb-6">
                LINE公式アカウントから<br />お問い合わせ
              </h2>

              <div class="space-y-4 mb-8">
                <div class="flex items-start gap-3">
                  <div class="flex-shrink-0 w-10 h-10 rounded-full bg-sakura-100 flex items-center justify-center">
                    <MessageCircle className="w-5 h-5 text-sakura-600" />
                  </div>
                  <div>
                    <h3 class="font-medium text-neutral-900">気軽にメッセージ</h3>
                    <p class="text-sm text-neutral-600">お気軽にメッセージをお送りください</p>
                  </div>
                </div>

                <div class="flex items-start gap-3">
                  <div class="flex-shrink-0 w-10 h-10 rounded-full bg-sakura-100 flex items-center justify-center">
                    <Clock className="w-5 h-5 text-sakura-600" />
                  </div>
                  <div>
                    <h3 class="font-medium text-neutral-900">24時間以内に返信</h3>
                    <p class="text-sm text-neutral-600">営業日24時間以内にご返信いたします</p>
                  </div>
                </div>
              </div>

              <Button
                href={LINE_CONFIG.url}
                size="lg"
                class="w-full bg-[#06C755] hover:bg-[#05b34d] border-none"
                target="_blank"
                rel="noopener noreferrer"
              >
                <svg class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
                </svg>
                LINEで問い合わせる
              </Button>
            </div>
          </FadeInSection>
        </div>
      </div>
    </Container>
  </section>

  {/* Flow Section */}
  <section class="py-16 md:py-20 bg-neutral-50">
    <Container>
      <FadeInSection client:idle>
        <h2 class="text-2xl md:text-3xl font-bold text-neutral-900 mb-12 text-center">
          お問い合わせの流れ
        </h2>
      </FadeInSection>

      <div class="max-w-3xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {[
            {
              step: 1,
              title: "LINE友だち追加",
              description: "QRコードまたはボタンからLINE公式アカウントを友だち追加",
            },
            {
              step: 2,
              title: "メッセージ送信",
              description: "ご相談内容やご質問をメッセージでお送りください",
            },
            {
              step: 3,
              title: "ご返信",
              description: "担当者から24時間以内にご返信いたします",
            },
          ].map((item, index) => (
            <FadeInSection client:idle delay={index * 0.1}>
              <div class="text-center">
                <div class="w-16 h-16 rounded-full bg-sakura-500 text-white flex items-center justify-center mx-auto mb-4 text-2xl font-bold">
                  {item.step}
                </div>
                <h3 class="text-lg font-bold text-neutral-900 mb-2">{item.title}</h3>
                <p class="text-neutral-600 text-sm">{item.description}</p>
              </div>
              {index < 2 && (
                <div class="hidden md:flex items-center justify-center absolute right-0 top-1/2 -translate-y-1/2 translate-x-1/2">
                  <ArrowRight className="w-6 h-6 text-sakura-300" />
                </div>
              )}
            </FadeInSection>
          ))}
        </div>
      </div>
    </Container>
  </section>

  {/* Info Section */}
  <section class="py-16 md:py-20">
    <Container>
      <div class="max-w-2xl mx-auto">
        <FadeInSection client:idle>
          <div class="bg-sakura-50 rounded-2xl p-8">
            <h2 class="text-xl font-bold text-neutral-900 mb-6 text-center">
              対応時間について
            </h2>

            <div class="space-y-4">
              <div class="flex items-center gap-3 justify-center">
                <Clock className="w-5 h-5 text-sakura-600" />
                <span class="text-neutral-700">
                  <strong>対応時間：</strong>平日 9:00〜18:00
                </span>
              </div>

              <div class="flex items-center gap-3 justify-center">
                <CheckCircle className="w-5 h-5 text-sakura-600" />
                <span class="text-neutral-700">
                  <strong>返信目安：</strong>24時間以内
                </span>
              </div>
            </div>

            <p class="mt-6 text-sm text-neutral-600 text-center">
              ※ 土日祝日・営業時間外のお問い合わせは、翌営業日にご返信いたします。
            </p>
          </div>
        </FadeInSection>
      </div>
    </Container>
  </section>

  <Footer />
</BaseLayout>
